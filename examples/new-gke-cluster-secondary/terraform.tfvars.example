# --- Common --- #
region                         = "<gcp-region>"
project_id                     = "<gcp-project-id>"
friendly_name_prefix           = "<sandbox>" # typically either environment (e.g., 'sandbox', 'nonprod', 'prod'), team name, or project name
is_secondary_region_deployment = true
common_labels = {
  app             = "tfe"
  env             = "<sandbox>"
  owner           = "<team-name>"
  tfe_region_role = "secondary"
}

# --- TFE config settings --- #
tfe_fqdn                   = "<tfe.example.com>"
create_helm_overrides_file = true

# --- Networking --- #
vpc_name               = "<my-tfe-vpc>" # must be same VPC as primary region deployment
create_tfe_lb_ip       = <true>
tfe_lb_ip_address_type = "<INTERNAL>"
tfe_lb_subnet_name     = "<my-tfe-lb-subnet-secondary>"
tfe_lb_ip_address      = "<10.0.0.30>" # Available IP address from `tfe_lb_subnet_name`
gke_subnet_name        = "<my-tfe-gke-subnet-secondary>"

# --- DNS (optional) --- #
create_tfe_cloud_dns_record = false # set to true when promoting secondary region to active
cloud_dns_zone_name         = "<dns-zone-name>"

# --- GKE --- #
create_gke_cluster                = true
gke_cluster_name                  = "<tfe-gke-cluster-secondary>"
gke_cluster_is_private            = <true>
gke_control_plane_authorized_cidr = "<192.168.1.0/24>" # CIDR of clients/workstations that need to access GKE cluster
gke_node_type                     = "n4-standard-4"
gke_node_count                    = 1 # number of nodes per zone

# --- Database --- #
postgres_db_is_replica        = true
postgres_master_instance_name = "<primary-tfe-cloud-sql-instance-name>"
postgres_deletion_protection  = true
