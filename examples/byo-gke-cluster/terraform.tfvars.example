# --- Common --- #
region                         = "<gcp-region>"
project_id                     = "<gcp-project-id>"
friendly_name_prefix           = "<sandbox>" # typically either environment (e.g., 'sandbox', 'nonprod', 'prod'), team name, or project name
is_secondary_region_deployment = false
common_labels = {
  app             = "tfe"
  env             = "<sandbox>"
  owner           = "<team-name>"
  tfe_region_role = "primary"
}

# --- TFE config settings --- #
tfe_fqdn                   = "<tfe.example.com>"
create_helm_overrides_file = true

# --- IAM --- #
tfe_gcp_svc_account_name = "<tfe-gcp-sa>"

# --- Networking --- #
vpc_name               = "<my-tfe-vpc>"
create_tfe_lb_ip       = <true>
tfe_lb_ip_address_type = "<INTERNAL>"
tfe_lb_subnet_name     = "<my-tfe-lb-subnet-primary>" # null if `tfe_lb_ip_address_type = "EXTERNAL"`
tfe_lb_ip_address      = "<10.0.0.20>" # Available IP address from `tfe_lb_subnet_name`; null if `tfe_lb_ip_address_type = "EXTERNAL"`

# --- Database --- #
tfe_database_user                    = "<tfe>"
tfe_database_password_secret_version = "<tfe-database-password-secret-name>"
postgres_db_is_replica               = false
postgres_master_instance_name        = null # only set for secondary region
postgres_deletion_protection         = true

# --- GCS bucket --- #
gcs_location                     = "<gcs-bucket-location>" # Either multi-region: US, EU, ASIA; or predefined dual-region pairing: NAM4, EUR4, ASIA1.
gcs_custom_dual_region_locations = ["<primary-gcp-region>", "<secondary-gcp-region>"] # Regions must be a valid GCP dual-region pair; null if `gcs_location` is already a predefined dual-region code (e.g., NAM4, EUR4, ASIA1)
gcs_rpo                          = "DEFAULT" # set to 'ASYNC_TURBO' for improved replication SLA when deploying dual-region pair
gcs_force_destroy                = false